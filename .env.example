# Örnek ortam değişkenleri (gerçek değerleri buraya yazma, .env kullan)

DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/DB"

AUTH_SECRET="replace_me"

ADMIN_EMAIL="info@example.com"
ADMIN_PASSWORD_HASH_B64="replace_me"

# Cloudinary (kalıcı görsel upload)
CLOUDINARY_CLOUD_NAME="replace_me"
CLOUDINARY_API_KEY="replace_me"
CLOUDINARY_API_SECRET="replace_me"

# Genel — kanonik site adresi (sitemap, metadata, isteğe bağlı istemci)
NEXT_PUBLIC_SITE_URL=https://www.mimarsametalp.com

# Auth.js v5 — üretimde zorunlu: openssl rand -base64 32
AUTH_SECRET=
# Oturum / OAuth yönlendirmeleri için taban URL (https ile, sonda / yok)
AUTH_URL=https://www.mimarsametalp.com
# Eski araçlar için (bazı istemciler hâlâ okur):
NEXTAUTH_URL=https://www.mimarsametalp.com

ADMIN_EMAIL=admin@mimarsametalp.com
# node scripts/hash-admin-password.mjs "Şifren" → ADMIN_PASSWORD_HASH_B64 satırını kopyala
ADMIN_PASSWORD_HASH_B64=

# Veritabanı — yerel SQLite örneği:
DATABASE_URL="file:./dev.db"
# Hostinger MySQL örneği (paneldeki bağlantı bilgisiyle):
# DATABASE_URL="mysql://KULLANICI:SIFRE@HOST:3306/VERITABANI"

# İletişim (Resend) — üretimde RESEND_API_KEY şart
RESEND_API_KEY=
RESEND_FROM_EMAIL=
CONTACT_INBOX_EMAIL=info@mimarsametalp.com
